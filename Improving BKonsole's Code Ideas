#define F_CPU 16000000UL
#include <avr/io.h>
#include <util/delay.h>
#include <stdlib.h>

#define DDR_SPI DDRB
#define DD_MOSI PB3
#define DD_SCK PB5
#define DD_SS PB2

#define MATRIX_SIZE 8
#define MAX_LENGTH 32

typedef struct {
    uint8_t x;
    uint8_t y;
} Point;

Point snake[MAX_LENGTH];
uint8_t snake_length = 3;
int8_t dir_x = 1, dir_y = 0; // hướng ban đầu: tăng hàng -> xuống dưới
Point food;
uint8_t hang[8];
uint8_t game_over_flag = 0;

void led(void){
    for (int i = 0; i < 8; i++){
        hang[i] = 0;
    }
    // vẽ thân rắn
    for (int i = 0; i < snake_length; i++){
        hang[snake[i].x] |= (1 << snake[i].y); //Bản chất là dịch bit
    }
    // vẽ thức ăn (nhấp nháy khi game over)
    if (!game_over_flag || (game_over_flag & 0x01)) {
        hang[food.x] |= (1 << food.y);
    }
}

void SPI_MasterInit(void) {
    DDR_SPI |= (1<<DD_MOSI) | (1<<DD_SCK) | (1<<DD_SS);
    SPCR = (1<<SPE) | (1<<MSTR) | (1<<SPR0); // Enable SPI, Master mode, f/16
}

void SPI_MasterTransmit(uint8_t cData) {
    SPDR = cData;
    while(!(SPSR & (1<<SPIF)));
}

void MAX7219_Send(uint8_t addr, uint8_t data) {
    PORTB &= ~(1<<DD_SS);
    SPI_MasterTransmit(addr);
    SPI_MasterTransmit(data);
    PORTB |= (1<<DD_SS);
}

void MAX7219_Init(void) {
    MAX7219_Send(0x0F, 0x00); // display test: off
    MAX7219_Send(0x0C, 0x01); // shutdown: normal
    MAX7219_Send(0x0B, 0x07); // scan limit = 8 LEDs
    MAX7219_Send(0x0A, 0x08); // intensity: medium
    MAX7219_Send(0x09, 0x00); // decode: none

    for (uint8_t i=1; i<=8; i++) {
        MAX7219_Send(i, 0x00); // clear all
    }
}

// Random từ min đến max (bao gồm cả min và max)
int randomRange(int min, int max) {
    return min + rand() % (max - min + 1);
}

// Cái này Thiên làm để cho food spawn ngẫu nhiên mỗi nơi mỗi lần chơi khác nhau
void init_random_seed(void) {
    // Cấu hình bộ ADC
    ADMUX = (1<<REFS0); // AVcc reference, ADC0
    ADCSRA = (1<<ADEN) | (1<<ADPS2) | (1<<ADPS1); // Enable ADC, prescaler 64
    
    uint16_t seed = 0;
    for (uint8_t i=0; i<16; i++) {
        ADCSRA |= (1 << ADSC); // Đọc tín hiệu analog (analog từ switch á)
        while(ADCSRA & (1 << ADSC)); // Sau khi đọc xong thì bit ADSC auto = 0, trong lúc bên trong while() = 1 thì vòng lặp chọn giá trị ngẫu nhiên sẽ chạy.
        seed = (seed << 1) | (ADC & 0x01); // Để Thiên giải thích chỗ này,...
// Lần lặp 1:
// - ADC đọc được: 0b0110101001 (giá trị ngẫu nhiên)
// - ADC & 0x01: 0b0110101001 & 0b0000000001 = 0b0000000001 = 1
// - seed << 1: 0b0000000000000000 << 1 = 0b0000000000000000 
// - seed = 0b0000000000000000 | 0b0000000000000001 = 0b0000000000000001 (*)

// Lần lặp 2:
// - ADC đọc được: 0b1010110110
// - ADC & 0x01: 0 (bit cuối = 0)
// - seed << 1: 0b0000000000000001 (*) << 1 = 0b0000000000000010
// - seed = 0b0000000000000010 | 0b0000000000000000 = 0b0000000000000010

// Lần lặp 3:
// - ADC đọc được: 0b0011010111
// - ADC & 0x01: 1
// - seed << 1: 0b0000000000000010 << 1 = 0b0000000000000100
// - seed = 0b0000000000000100 | 0b0000000000000001 = 0b0000000000000101

// ... (tiếp tục đến khi lặp đủ 16 lần)
// Kết quả cuối: seed = 0b1010110100110101 (ngẫu nhiên 16 bit) -> bỏ vô hàm srand(seed) sẽ cho ra số i (chuyển đổi ntn mấy fen gg i @@)
//                        ^
//						  |
//						  |
//  			    lặp lần 1 tại đây @@

// Vì sao Thiên chỉ lấy LSB? Mấy fen thấy á mỗi lần lặp thì cái LSB thay đổi nhiều nhất -> srand() sẽ cho ra vị trí ngẫu nhiên hoàn toàn khác nhau mỗi lần chơi.
    }
    srand(seed);
}

void clearMatrix(void) {
    for (uint8_t i=1; i<=8; i++) {
        MAX7219_Send(i, 0x00);
    }
}

// Hàm gởi dữ liệu lên Led Ma trận. Lưu ý: Led Ma trận chỉ nhận dữ liệu từ 1 -> 8.
void drawRows(uint8_t x, uint8_t y) {
    if (x <= 8) {
        MAX7219_Send(x, y);
    }
}

void spawnFood(void) {
    int valid;
    do {
        valid = 1; // giả sử vị trí hợp lệ
        food.x = randomRange(0,7);
        food.y = randomRange(0,7);

        // kiểm tra có trùng với thân rắn không
        for (int i = 0; i < snake_length; i++) {
            if (snake[i].x == food.x && snake[i].y == food.y) {
                valid = 0; // trùng → không hợp lệ
                break;
            }
        }
    } while (!valid); // nếu trùng thì sinh lại
}

uint8_t checkCollision(Point head) {
    for (uint8_t i=1; i<snake_length; i++) {
        if (head.x == snake[i].x && head.y == snake[i].y) return 1;
    }
    return 0;
}

// Thiên mới thêm ^^
void gameOver(void) {
    // Nhấp nháy 3 lần
    for (uint8_t blink = 0; blink < 6; blink++) {
        if (blink & 0x01) {
            clearMatrix(); // blink là số lẻ thì tắt led, tổng có 3 lần tắt với khoảng tgian cách đều cho nó đẹp =))).
        } else {
            for (int i = 0; i < 8; i++){
                drawRows( i + 1, hang[i]); // Hiện led hàng thứ i
            }
        }
        _delay_ms(200);
    }
    
    // Reset snake
    snake_length = 3;
    snake[0].x = 3; snake[0].y = 4;
    snake[1].x = 3; snake[1].y = 3;
    snake[2].x = 3; snake[2].y = 2;
    dir_x = 1; dir_y = 0;
    spawnFood();
    game_over_flag = 0;
}

void moveSnake(void) {
    Point newHead;
    newHead.x = (snake[0].x + dir_x + MATRIX_SIZE) % MATRIX_SIZE;
    newHead.y = (snake[0].y + dir_y + MATRIX_SIZE) % MATRIX_SIZE;

    if (checkCollision(newHead)) {
        game_over_flag = 1;
        gameOver();
        return;
    }

    // Di chuyển thân rắn
    for (int i = snake_length; i > 0; i--) {
        snake[i] = snake[i-1];
    }
    snake[0] = newHead;

    // Kiểm tra ăn thức ăn
    if (newHead.x == food.x && newHead.y == food.y) {
        if (snake_length < MAX_LENGTH) {
            snake_length++;
        }
        spawnFood();
    }
}

// Update code tích hợp Chống rung - Debounce ^^
void check_button(void){
    static uint8_t last_button = 0xFF; // Định nghĩa các nút ban đầu chưa được nhấn
    uint8_t current_button = PIND & 0x0F; // Đọc toàn bộ PORTD và lấy 4 bit cuối (tức là bit PD0 -> PD3)
    
    // Xử lý chống rung khi trạng thái button thay đổi
    if (current_button == last_button) return;
    last_button = current_button; 
    
	// Tạo biến vị trí con rắn tạm, nếu k có nút nào nhấn thì vị trí giữ nguyên.
    int8_t new_dir_x = dir_x;
    int8_t new_dir_y = dir_y;
    
    if ((PIND & (1 << PD0)) == 0) { //PD0 nhấn, rắn di chuyển lên TRÊN
        new_dir_x = -1;
        new_dir_y = 0;
    }
    else if ((PIND & (1 << PD1)) == 0) { //PD1 nhấn, rắn di chuyển sang TRÁI
        new_dir_x = 0;
        new_dir_y = -1;
    }
    else if ((PIND & (1 << PD2)) == 0) { //PD2 nhấn, rắn di chuyển sang PHẢI
        new_dir_x = 0;
        new_dir_y = 1;
    }
    else if ((PIND & (1 << PD3)) == 0) { //PD3 nhấn, rắn di chuyển xuống DƯỚI
        new_dir_x = 1;
        new_dir_y = 0;
    }
    else {
        return; // Không có nút nào được nhấn
    }
    
    // Ngăn rắn quay đầu 180 độ 
	// Ví dụ rắn đang đi sang PHẢI, nhấn TRÁI, nếu k ktra thì rắn tự đâm đầu vào mình -> game over
    // Vòng lặp: kiểm tra hướng đi có ĐỐI DIỆN hướng cũ hay kh?
    // Có: BỎ QUA khỏi làm cái gì
    // Không: CẬP NHẬT biến dir_ mới
    if (new_dir_x != -dir_x || new_dir_y != -dir_y) {
        dir_x = new_dir_x;
        dir_y = new_dir_y;
    }
}

int main(void) {
    DDRD = 0x00;  // PORT INPUT
    PORTD = 0xFF; // DIEN TRO KEO
 
    SPI_MasterInit();
    MAX7219_Init();
    init_random_seed();
    
    // Khởi tạo rắn
    snake[0].x = 3; snake[0].y = 4;
    snake[1].x = 3; snake[1].y = 3;
    snake[2].x = 3; snake[2].y = 2;
    snake_length = 3;
    dir_x = 1; dir_y = 0;
    
    spawnFood();
    
    uint16_t frame_counter = 0; // biến điều chỉnh tốc độ chạy của rắn
    
    while(1){
        clearMatrix();
        check_button();
        
        // Di chuyển rắn mỗi 15 frame (15 x 20ms = 300ms)
        // Muốn tăng giảm tốc độ rắn thì tăng giảm con số 15, vd muốn nhanh hơn thì giảm còn 10, chậm hơn thì tăng lên 20 kiểu kiểu vậy
        if (++frame_counter >= 15) {
            frame_counter = 0;
            moveSnake();
        }
        
        led();
        for (int i = 0; i < 8; i++){
            drawRows( i + 1, hang[i]);
        }
        _delay_ms(20);
    }
}
